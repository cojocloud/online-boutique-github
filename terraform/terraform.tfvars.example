# Root-level tfvars — used only when running terraform from terraform/ directly.
# For the environment-specific configs (recommended), use:
#   terraform/environments/dev/terraform.tfvars.example
#   terraform/environments/prod/terraform.tfvars.example
# NOTE: `environment` is a root-level-only variable; do NOT include it in env-specific tfvars.

aws_region         = "us-east-1"
cluster_name       = "online-boutique"
environment        = "dev"
kubernetes_version = "1.30"
namespace          = "online-boutique"

# VPC
vpc_cidr           = "10.0.0.0/16"
availability_zones = []   # leave empty to auto-select 3 AZs

# Node group
node_instance_types = ["t3.medium"]
node_desired_size   = 3
node_min_size       = 2
node_max_size       = 6
node_disk_size      = 50

# Set to true to replace in-cluster Redis with AWS ElastiCache
enable_elasticache    = false
elasticache_node_type = "cache.t3.micro"

# ── GitHub OIDC (replaces long-lived AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
# After `terraform apply`, copy the `github_ci_role_arn` output and set it as
# GH_AWS_ROLE_ARN in GitHub → Settings → Secrets and variables → Actions → Variables.

github_repository = "your-github-org/online-boutique"
tf_state_bucket   = "tf-state-online-boutique-github"
tf_lock_table     = "tf-state-lock-github"
